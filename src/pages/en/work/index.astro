---
import Base from '../../../layouts/Base.astro';
import PageHero from '../../../components/PageHero.astro';
import WorkEmpty from '../../../components/WorkEmpty.astro';
import { t } from '../../../i18n/utils';

const locale = 'en' as const;
const tt = t(locale);
---

<Base
  locale={locale}
  title={`${tt('work.title')} — kenmartz`}
  description={tt('work.lede')}
  canonicalPath="/work/"
>
  <PageHero eyebrow="2025" title={tt('work.title')} lede={tt('work.lede')} />
  <WorkEmpty locale={locale} />
</Base>
