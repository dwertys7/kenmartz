---
import Base from '../../../layouts/Base.astro';
import PageHero from '../../../components/PageHero.astro';
import StudioPrinciples from '../../../components/StudioPrinciples.astro';
import { t } from '../../../i18n/utils';

const locale = 'ru' as const;
const tt = t(locale);
---

<Base
  locale={locale}
  title={`${tt('studio.title')} — kenmartz`}
  description={tt('studio.lede')}
  canonicalPath="/studio/"
>
  <PageHero eyebrow="A–Z" title={tt('studio.title')} lede={tt('studio.lede')} />
  <StudioPrinciples locale={locale} />
</Base>
