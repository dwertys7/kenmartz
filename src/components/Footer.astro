---
import { type Locale } from '../i18n/ui';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tt = t(locale);
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 mt-24">
  <div class="mx-auto flex max-w-screen-2xl flex-col gap-2 px-6 py-8 text-xs text-(--color-mute) md:flex-row md:items-center md:justify-between md:px-10">
    <p>© {year} kenmartz. {tt('footer.rights')}</p>
    <p class="font-mono">Tbilisi · Berlin · Remote</p>
  </div>
</footer>
