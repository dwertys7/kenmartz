---
import { type Locale } from '../i18n/ui';
import { t, localizedPath } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tt = t(locale);
---

<section class="mx-auto max-w-screen-2xl px-6 py-20 md:px-10 md:py-32">
  <div class="grid place-items-center">
    <div class="max-w-xl text-center">
      <p
        class="mb-6 font-mono text-[10px] uppercase tracking-[0.3em] text-(--color-mute)"
      >
        ◇ ◇ ◇
      </p>
      <p class="font-display text-2xl text-(--color-paper)/90 md:text-3xl">
        {tt('work.empty')}
      </p>
      <a
        href={localizedPath(locale, '/contact/')}
        class="mt-10 inline-flex items-center gap-2 rounded-full border border-white/20 px-5 py-3 text-sm transition hover:border-(--color-accent)"
      >
        {tt('home.cta')} <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
